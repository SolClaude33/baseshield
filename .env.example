# Vercel Postgres (set automatically when you connect the integration)
POSTGRES_URL=

# Iron-session cookie secret — generate one with: openssl rand -base64 32
SESSION_SECRET=

# WalletConnect project id (free) — https://cloud.reown.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Alchemy API key for Base RPC — https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_KEY=

# Alchemy webhook signing secret (Notify) — for /api/webhook/alchemy
ALCHEMY_WEBHOOK_SECRET=

# LLM provider — single Ark key serves all models
ARK_API_KEY=                                                       # ark-XXXXXXXX-...
ARK_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3        # International (BytePlus)
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3            # China (Volcengine)

# The USDC address on Base where users deposit
NEXT_PUBLIC_DEPOSIT_ADDRESS=0x0000000000000000000000000000000000000000

# Public app URL (used in SIWE messages)
NEXT_PUBLIC_APP_URL=http://localhost:3000
